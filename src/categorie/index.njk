---
layout: layouts/base.njk
title: Categorie
description: Panoramica delle categorie del sito.
---
<section class="page">
  <header class="hero hero-compact">
    <p class="eyebrow">Categorie</p>
    <h1>Sezioni editoriali</h1>
    <p class="lead">Ogni storia del sito e stata assegnata a una sezione stabile per trasformare la pagina unica in una piccola testata navigabile.</p>
  </header>

  <section class="grid category-grid">
    {% for category in categories %}
    <article class="card">
      <p class="eyebrow">{{ category.name }}</p>
      <h2><a href="{{ ('/categorie/' + category.slug + '/') | url }}">{{ category.name }}</a></h2>
      <p>{{ category.deck }}</p>
      <a class="text-link" href="{{ ('/categorie/' + category.slug + '/') | url }}">Apri la sezione</a>
    </article>
    {% endfor %}
  </section>
</section>
