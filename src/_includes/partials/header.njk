<header class="site-header">
  <div class="shell shell-header">
    <a class="brand" href="{{ '/' | url }}">{{ site.name }}</a>
    <nav class="site-nav" aria-label="Navigazione principale">
      {% for item in navigation %}
      <a href="{{ item.url | url }}">{{ item.label }}</a>
      {% endfor %}
    </nav>
  </div>
</header>
